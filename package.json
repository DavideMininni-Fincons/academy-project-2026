{
  "name": "academy-project-2026",
  "version": "0.0.0",
  "main": "dist/main.js",
  "scripts": {
    "build": "npm run build:css && npm run build:ts",
    "build:css": "sass src/styles.scss dist/styles.css",
    "build:ts": "tsc",
    "watch": "npm run watch:css & npm run watch:ts",
    "watch:css": "sass --watch src/styles.scss:dist/styles.css",
    "watch:ts": "tsc --watch"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "sass": "^1.69.5"
  }
}
